  color: #DEDEDE;
}
:-moz-placeholder {
  color: #DEDEDE;
}.logo { 
    filter: grayscale(100%); 
    max-height: 400px; 
} 

.logo img { 
    max-height: 400px; 
    width: auto; 
}</style>

